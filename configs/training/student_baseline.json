    "learning_rate": 0.001,
    "weight_decay": 0.0001,
    "num_workers": 2,
    "val_fraction": 0.1,
    "seed": 42
  },
  "model": {
    "name": "simple_heatmap_student",
    "width": 48
  },
  "metrics": ["pck", "oks", "latency_ms", "fps"]
}
